# LAW-GPT Environment Configuration

# 1. Zilliz Cloud (Milvus) Configuration
ZILLIZ_TOKEN="your_zilliz_token_here"

# 2. Supabase Configuration (Metadata & User DB)
SUPABASE_URL="https://your_supabase_url.supabase.co"
SUPABASE_KEY="your_supabase_service_role_key_here"

# 3. Cerebras API (Fast LLM Inference)
CEREBRAS_API_KEY="your_cerebras_api_key_here"

# 4. Serper API (Web Search for Agents)
SERPER_API_KEY="your_serper_api_key_here"

# 5. Indian Kanoon API (Statute Lookup)
INDIAN_KANOON_API_TOKEN="your_kanoon_token_here"

# 6. Hugging Face Token (Model & Dataset Access)
HF_TOKEN="your_huggingface_token_here"

# 7. NVIDIA API Key (Embeddings)
NVIDIA_API_KEY="your_nvidia_api_key_here"
